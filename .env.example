# Resend Configuration
# Get your API key from https://resend.com
RESEND_API_KEY=re_your_api_key_here

# The display name for outgoing emails
RESEND_FROM_NAME=DeAI Summit

# The sender email address (Must be verified in Resend)
RESEND_FROM_EMAIL=contact@deaisummit.org

# The inbox where you want to receive form submissions
RESEND_TO_EMAIL=contact@deaisummit.org

# Backend API (SSR prefetch). Dashboard → Integrations → Website API Key (tenant API key) must match
# the tenant where you configure Settings → Analytics tags, or snippets stay empty locally.
NEXT_PUBLIC_GCONF_API_URL=http://localhost:3000/api
GCONF_API_KEY=

# Analytics (GTM, GA4, LinkedIn, Reddit, GSC): Dashboard → Settings → Analytics tags only
# — loaded at build/request time via the API URL + tenant key above.
